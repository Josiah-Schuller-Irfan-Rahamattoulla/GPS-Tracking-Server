# PostgreSQL Configuration
POSTGRES_USER=gpsuser
POSTGRES_PASSWORD=gpspassword
POSTGRES_DB=gps_tracking

# API Configuration (required)
# For Docker Compose this is set from POSTGRES_*; for standalone set explicitly:
# DATABASE_URI=postgresql://gpsuser:gpspassword@localhost:5432/gps_tracking

# nRF Cloud (A-GNSS) – optional; device GET /v1/agnss returns 503 if unset
NRF_CLOUD_API_KEY=

# Optional: AGNSS_PROVIDER=NRF_CLOUD|SUPL (default: try both). SUPL_DEMO=1 for SUPL demo.
# AGNSS_CACHE_PATH=  AGNSS_CACHE_TTL_SEC=

# Optional: cell location provider (device POST /v1/cell_location). One of: nrf_cloud, google, here, auto
# CELL_LOCATION_PROVIDER=nrf_cloud
# GOOGLE_GEOLOCATION_API_KEY=  HERE_API_KEY=

# Production: restrict CORS to your app/website origins (comma-separated). Leave empty for allow-all.
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
# =============================================================================
# NOTIFICATION SETTINGS
# =============================================================================

# Email Notifications (SMTP)
# Enable email notifications for geofence breaches
NOTIFY_GEOFENCE_EMAIL=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=GPS Tracker <your-email@gmail.com>

# SMS Notifications - Twilio
# Enable SMS notifications via Twilio
NOTIFY_GEOFENCE_SMS_TWILIO=false
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_PHONE=+1234567890

# SMS Notifications - AWS SNS (alternative to Twilio)
# Enable SMS notifications via AWS SNS
NOTIFY_GEOFENCE_SMS_AWS=false
AWS_REGION=us-east-1
# AWS credentials via environment or IAM role:
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret