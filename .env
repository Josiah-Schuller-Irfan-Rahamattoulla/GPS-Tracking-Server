# API keys
# NRF_CLOUD_API_KEY requires a Service Account API key (not device provisioning key)
# Get it from nRF Cloud portal: API → Service Accounts
NRFCLOUD_OAT=oat_mtIr0R9HS8E5RM0YduT4u9Qid19zObEz
NRFCLOUD_ORG_SLUG=your-org-slug
NRFCLOUD_PROJECT_SLUG=your-project-slug

# Providers
# Leave AGNSS_PROVIDER empty to try nRF Cloud first, then fallback to Google SUPL
AGNSS_PROVIDER=
# SUPL_DEMO=1 returns sample data (for testing only, set to 0 for production)
SUPL_DEMO=0
CELL_LOCATION_PROVIDER=auto

# A-GNSS cache
AGNSS_CACHE_TTL_SEC=7200
# AGNSS_CACHE_PATH=/app/agnss_cache.bin

